{
  "name": "Bhashyapyc Dev",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    }
  },
  "postCreateCommand": "pip install -e . && npm install && npm run compile",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pytest",
        "dbaeumer.vscode-eslint"
      ],
      "settings": {
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": ["tests"]
      }
    }
  },
  "forwardPorts": []
}
