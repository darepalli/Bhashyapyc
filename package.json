{
  "name": "bhashyapyc",
  "displayName": "Bhashyapyc – Python ↔ Indian Language Translator",
  "description": "Hover over code to see bidirectional translations between Python and Indian languages (Telugu & Sanskrit). Displays translated code as a balloon popup.",
  "version": "0.1.0",
  "publisher": "bhashyapyc",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/darepalli/Bhashyapyc"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Education"
  ],
  "keywords": [
    "telugu",
    "sanskrit",
    "indian languages",
    "python",
    "translation",
    "bhashya"
  ],
  "activationEvents": [
    "onLanguage:python",
    "onLanguage:telugu-python",
    "onLanguage:sanskrit-python"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "telugu-python",
        "aliases": [
          "Telugu Python",
          "tepy"
        ],
        "extensions": [
          ".tepy"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "sanskrit-python",
        "aliases": [
          "Sanskrit Python",
          "sapy"
        ],
        "extensions": [
          ".sapy"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": {
      "title": "Bhashyapyc",
      "properties": {
        "bhashyapyc.pythonPath": {
          "type": "string",
          "default": "python3",
          "description": "Path to the Python interpreter that has bhashyapyc installed."
        },
        "bhashyapyc.targetLanguage": {
          "type": "string",
          "default": "te",
          "enum": [
            "te",
            "sa"
          ],
          "enumDescriptions": [
            "Telugu (తెలుగు)",
            "Sanskrit (संस्कृत)"
          ],
          "description": "Target Indian language for reverse translation of Python code."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.3.0"
  }
}
